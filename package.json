{
  "name": "verdun",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:app": "vite --host 127.0.0.1 --port 5176 --strictPort",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "prod:build": "vue-tsc -b && vite build --outDir dist-prod",
    "prod:app": "vite preview --host 127.0.0.1 --port 5174 --strictPort --outDir dist-prod",
    "smoke:app": "node scripts/smoke-app.mjs",
    "smoke:api": "node scripts/smoke-api-local.mjs",
    "smoke:api-http": "node scripts/smoke-api-http.mjs",
    "smoke:draft": "node scripts/smoke-draft-local.mjs",
    "smoke:draft-url": "node scripts/smoke-draft-url.mjs",
    "smoke:ghost": "node scripts/smoke-ghost.mjs",
    "smoke:readiness": "node scripts/smoke-readiness.mjs",
    "draft": "node scripts/newsletter-draft.mjs",
    "ulysses:draft": "node scripts/newsletter-draft.mjs --ulysses",
    "ghost:draft": "node scripts/publish-ghost.mjs"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "@neondatabase/serverless": "^1.1.0",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8"
  }
