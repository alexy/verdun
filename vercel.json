{
  "framework": "vite",
  "buildCommand": "npm run prod:build",
  "outputDirectory": "dist-prod",
  "redirects": [
    {
      "source": "/",
      "destination": "/rbage/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/rbage/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
